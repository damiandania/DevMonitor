  "strings" : {
    "%@ build completed successfully." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La compilación de %@ finalizó con éxito." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le build de %@ a réussi." } }
      }
    },
    "%@ build failed." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Falló la compilación de %@." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Le build de %@ a échoué." } }
      }
    },
    "%@ exited with code %lld." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "%@ salió con el código %lld." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "%@ s'est arrêté avec le code %lld." } }
      }
    },
    "%@ is responding again." : {
      "localizations" : {
        "es" : { "stringUnit" : { "state" : "translated", "value" : "%@ vuelve a responder." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "%@ répond à nouveau." } }
